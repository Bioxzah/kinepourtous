---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout titre="Accueil">
  <div class="home">
    <div class="intro">
      <p class="intro-label">Cabinet de kinésithérapie</p>
      <h1>Kiné Pour Tous</h1>
      <p class="intro-sub">Sélectionnez une zone anatomique pour accéder à vos fiches d'exercices.</p>
    </div>

    <div class="body-container">
      <svg viewBox="0 0 200 420" xmlns="http://www.w3.org/2000/svg" class="body-svg" aria-label="Corps humain cliquable par zone">

        <!-- Tête → toutes les fiches -->
        <a href="/fiches">
          <g class="bz" aria-label="Toutes les fiches">
            <ellipse cx="100" cy="50" rx="28" ry="33"/>
          </g>
        </a>

        <!-- Cou (visuel) -->
        <rect x="92" y="82" width="16" height="13" fill="#EFF2E5" stroke="rgba(70,80,40,0.18)" stroke-width="1" style="pointer-events:none"/>

        <!-- Buste → Dos -->
        <a href="/fiches?zone=dos">
          <g class="bz" aria-label="Dos">
            <path d="M62 94 C60 140 63 185 66 205 L134 205 C137 185 140 140 138 94 Q120 87 100 87 Q80 87 62 94 Z"/>
            <text class="bz-lbl" x="100" y="152">DOS</text>
          </g>
        </a>

        <!-- Bassin → Dos -->
        <a href="/fiches?zone=dos">
          <g class="bz" aria-label="Dos · Bassin">
            <path d="M66 206 C64 222 66 240 70 250 Q84 258 100 258 Q116 258 130 250 C134 240 136 222 134 206 Z"/>
          </g>
        </a>

        <!-- Épaule gauche -->
        <a href="/fiches?zone=%C3%A9paule">
          <g class="bz" aria-label="Épaule">
            <path d="M62 96 C42 104 30 122 28 142 L44 146 C46 132 54 116 70 108 Z"/>
          </g>
        </a>

        <!-- Avant-bras gauche → Coude -->
        <a href="/fiches?zone=coude">
          <g class="bz" aria-label="Coude">
            <path d="M28 144 C22 168 22 196 26 218 L42 215 C38 196 36 170 44 148 Z"/>
          </g>
        </a>

        <!-- Épaule droite -->
        <a href="/fiches?zone=%C3%A9paule">
          <g class="bz" aria-label="Épaule">
            <path d="M138 96 C158 104 170 122 172 142 L156 146 C154 132 146 116 130 108 Z"/>
          </g>
        </a>

        <!-- Avant-bras droit → Coude -->
        <a href="/fiches?zone=coude">
          <g class="bz" aria-label="Coude">
            <path d="M172 144 C178 168 178 196 174 218 L158 215 C162 196 164 170 156 148 Z"/>
          </g>
        </a>

        <!-- Genou gauche -->
        <a href="/fiches?zone=genou">
          <g class="bz" aria-label="Genou">
            <rect x="66" y="260" width="30" height="64" rx="8"/>
          </g>
        </a>

        <!-- Genou droit -->
        <a href="/fiches?zone=genou">
          <g class="bz" aria-label="Genou">
            <rect x="104" y="260" width="30" height="64" rx="8"/>
          </g>
        </a>

        <!-- Cheville gauche -->
        <a href="/fiches?zone=cheville">
          <g class="bz" aria-label="Cheville">
            <rect x="66" y="327" width="30" height="58" rx="6"/>
          </g>
        </a>

        <!-- Cheville droite -->
        <a href="/fiches?zone=cheville">
          <g class="bz" aria-label="Cheville">
            <rect x="104" y="327" width="30" height="58" rx="6"/>
          </g>
        </a>

        <!-- Pied gauche -->
        <a href="/fiches?zone=pied">
          <g class="bz" aria-label="Pied">
            <ellipse cx="81" cy="393" rx="22" ry="10"/>
          </g>
        </a>

        <!-- Pied droit -->
        <a href="/fiches?zone=pied">
          <g class="bz" aria-label="Pied">
            <ellipse cx="119" cy="393" rx="22" ry="10"/>
          </g>
        </a>

        <!-- Labels côté gauche -->
        <text class="side-lbl" x="2" y="122" text-anchor="start">Épaule</text>
        <line x1="28" y1="119" x2="52" y2="119" stroke="rgba(70,80,40,0.15)" stroke-width="0.8"/>

        <text class="side-lbl" x="2" y="183" text-anchor="start">Coude</text>
        <line x1="28" y1="180" x2="37" y2="180" stroke="rgba(70,80,40,0.15)" stroke-width="0.8"/>

        <text class="side-lbl" x="2" y="296" text-anchor="start">Genou</text>
        <line x1="40" y1="293" x2="66" y2="293" stroke="rgba(70,80,40,0.15)" stroke-width="0.8"/>

        <text class="side-lbl" x="2" y="360" text-anchor="start">Cheville</text>
        <line x1="46" y1="357" x2="66" y2="357" stroke="rgba(70,80,40,0.15)" stroke-width="0.8"/>

        <text class="side-lbl" x="100" y="412" text-anchor="middle">Pied</text>

      </svg>
    </div>

    <div class="zone-tags">
      <a href="/fiches?zone=%C3%A9paule" class="ztag">Épaule</a>
      <a href="/fiches?zone=dos" class="ztag">Dos</a>
      <a href="/fiches?zone=coude" class="ztag">Coude</a>
      <a href="/fiches?zone=genou" class="ztag">Genou</a>
      <a href="/fiches?zone=cheville" class="ztag">Cheville</a>
      <a href="/fiches?zone=pied" class="ztag">Pied</a>
      <a href="/fiches" class="ztag ztag-all">Toutes les fiches →</a>
    </div>
  </div>
</BaseLayout>

<style>
  .home {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
    padding: 2rem 0 3rem;
  }

  .intro {
    text-align: center;
    max-width: 480px;
  }
  .intro-label {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--bleu);
    margin-bottom: 0.5rem;
  }
  .intro h1 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    color: var(--vert);
    margin-bottom: 0.6rem;
    font-weight: 700;
  }
  .intro-sub {
    font-size: 0.92rem;
    color: var(--gris);
    line-height: 1.5;
  }

  .body-container {
    width: 100%;
    max-width: 240px;
  }

  .body-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .bz { cursor: pointer; }
  .bz ellipse, .bz path, .bz rect {
    fill: #EFF2E5;
    stroke: rgba(70,80,40,0.22);
    stroke-width: 1.2;
    transition: fill 0.18s, stroke 0.18s, stroke-width 0.18s;
  }
  .bz:hover ellipse, .bz:hover path, .bz:hover rect {
    fill: rgba(105,122,52,0.28);
    stroke: #697A34;
    stroke-width: 1.8;
  }

  .bz-lbl {
    font-family: system-ui, sans-serif;
    font-size: 7px;
    fill: rgba(70,80,40,0.45);
    pointer-events: none;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .side-lbl {
    font-family: system-ui, sans-serif;
    font-size: 6.5px;
    fill: rgba(70,80,40,0.38);
    pointer-events: none;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .zone-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    justify-content: center;
    max-width: 340px;
  }
  .ztag {
    border: 1px solid rgba(70,80,40,0.22);
    color: var(--gris);
    padding: 0.3rem 0.75rem;
    font-size: 0.8rem;
    border-radius: var(--rayon);
    text-decoration: none;
    transition: all 0.15s;
    background: white;
  }
  .ztag:hover {
    border-color: var(--bleu);
    color: var(--bleu);
    background: var(--bleu-clair);
  }
  .ztag-all {
    border-color: var(--bleu);
    color: var(--bleu);
    font-weight: 600;
  }
  .ztag-all:hover {
    background: var(--bleu);
    color: white;
  }
</style>
