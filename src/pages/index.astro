---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const fiches = await getCollection('fiches');
const dernieresFiches = fiches.slice(0, 3);
---
<BaseLayout titre="Accueil">
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-label">Cabinet de kinésithérapie</p>
      <h1>Vos exercices de kiné,<br/>partout et à tout moment</h1>
      <p class="hero-sub">Retrouvez toutes vos fiches d'exercices classées par pathologie et zone anatomique. Consultables sur mobile, téléchargeables en PDF.</p>
      <div class="hero-actions">
        <a href="/fiches" class="btn-primary">Voir toutes les fiches</a>
        <a href="/contact" class="btn-secondary">Prendre rendez-vous</a>
      </div>
    </div>
  </section>

  <section class="stats">
    <div class="stat">
      <span class="stat-number">{fiches.length}</span>
      <span class="stat-label">fiches d'exercices</span>
    </div>
    <div class="stat">
      <span class="stat-number">PDF</span>
      <span class="stat-label">téléchargeables</span>
    </div>
    <div class="stat">
      <span class="stat-number">100%</span>
      <span class="stat-label">gratuit</span>
    </div>
  </section>

  <section class="dernieres-fiches">
    <h2>Dernières fiches ajoutées</h2>
    <div class="grid">
      {dernieresFiches.map(fiche => (
        <a href={`/fiches/${fiche.slug}`} class="card">
          <span class="badge">{fiche.data.zone}</span>
          <h3>{fiche.data.titre}</h3>
          <p>{fiche.data.description}</p>
          <div class="card-footer">
            <span class="niveau">{fiche.data.niveau}</span>
            {fiche.data.duree && <span class="duree">{fiche.data.duree}</span>}
          </div>
        </a>
      ))}
    </div>
    <div class="voir-tout">
      <a href="/fiches" class="btn-outline">Voir toutes les fiches →</a>
    </div>
  </section>

  <section class="cabinet">
    <div class="cabinet-inner">
      <div class="cabinet-texte">
        <h2>Le cabinet</h2>
        <p>Des fiches d'exercices professionnelles, créées par votre kinésithérapeute, pour accompagner votre rééducation à domicile en toute sécurité.</p>
        <div class="cabinet-adresse">
          <span class="cabinet-icon">📍</span>
          <span>Adresse du cabinet — à compléter</span>
        </div>
        <a href="/contact" class="btn-primary" style="margin-top:1rem;display:inline-block">Contact & RDV</a>
      </div>
      <div class="cabinet-zones">
        <h3>Zones traitées</h3>
        <div class="zones-liste">
          {['Dos', 'Épaule', 'Genou', 'Cheville', 'Pied', 'Coude'].map(z => (
            <span class="zone-tag">{z}</span>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
    border-radius: 1rem;
    padding: 4rem 2rem;
    text-align: center;
    margin-bottom: 2rem;
  }
  .hero-label {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--bleu);
    margin-bottom: 0.75rem;
  }
  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 3rem);
    margin-bottom: 1rem;
    color: #14532d;
    line-height: 1.2;
  }
  .hero-sub {
    font-size: 1.1rem;
    color: var(--gris);
    max-width: 560px;
    margin: 0 auto 2rem;
  }
  .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-secondary {
    display: inline-block;
    background: white;
    color: var(--bleu);
    border: 2px solid var(--bleu);
    padding: 0.75rem 1.5rem;
    border-radius: var(--rayon);
    text-decoration: none;
    font-weight: 600;
  }
  .btn-secondary:hover { background: var(--bleu-clair); }
  .btn-outline {
    display: inline-block;
    border: 2px solid var(--bleu);
    color: var(--bleu);
    padding: 0.6rem 1.4rem;
    border-radius: var(--rayon);
    text-decoration: none;
    font-weight: 600;
  }
  .btn-outline:hover { background: var(--bleu-clair); }

  .stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    padding: 2rem;
    background: white;
    border-radius: var(--rayon);
    border: 1px solid #e5e7eb;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }
  .stat { text-align: center; }
  .stat-number { display: block; font-size: 2rem; font-weight: 800; color: var(--bleu); }
  .stat-label { font-size: 0.85rem; color: var(--gris); }

  .voir-tout { text-align: center; margin-top: 2rem; }

  .cabinet {
    background: #14532d;
    border-radius: 1rem;
    padding: 3rem 2rem;
    margin-top: 3rem;
    color: white;
  }
  .cabinet-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
  .cabinet h2 { color: white; font-size: 1.6rem; margin-bottom: 1rem; }
  .cabinet p { color: #bbf7d0; margin-bottom: 1rem; }
  .cabinet-adresse { display: flex; align-items: center; gap: 0.5rem; color: #bbf7d0; }
  .cabinet-zones h3 { color: white; margin-bottom: 1rem; }
  .zones-liste { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .zone-tag {
    background: rgba(255,255,255,0.15);
    color: white;
    padding: 0.3rem 0.8rem;
    border-radius: 9999px;
    font-size: 0.85rem;
  }
  @media (max-width: 640px) {
    .cabinet-inner { grid-template-columns: 1fr; }
    .stats { gap: 1.5rem; }
  }
</style>
