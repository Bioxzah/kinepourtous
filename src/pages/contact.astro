---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout titre="Contact & RDV" description="Contactez le cabinet de kinésithérapie ou prenez rendez-vous en ligne.">
  <section class="contact-page">
    <h1>Contact & Rendez-vous</h1>

    <div class="contact-grid">
      <div class="contact-infos">
        <h2>Cabinet</h2>
        <p>📍 Adresse du cabinet</p>
        <p>📞 01 23 45 67 89</p>
        <p>📧 contact@kinepourtous.fr</p>

        <h2>Horaires</h2>
        <p>Lundi – Vendredi : 8h – 19h</p>
        <p>Samedi : 8h – 12h</p>
      </div>

      <div class="rdv-bloc">
        <h2>Prendre rendez-vous</h2>
        <p>Réservez directement en ligne via Doctolib :</p>
        <!-- Remplacer par le vrai lien Doctolib -->
        <a href="#" class="btn-primary btn-doctolib">Prendre RDV sur Doctolib</a>
      </div>
    </div>
  </section>
</BaseLayout>
