---
interface Props {
  titre: string;
  description?: string;
}
const { titre, description = 'Fiches d\'exercices de kinésithérapie par pathologie.' } = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{titre} — Kiné Pour Tous</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="stylesheet" href="/styles/global.css" />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">Kiné Pour Tous</a>
        <ul>
          <li><a href="/fiches">Fiches d'exercices</a></li>
          <li><a href="/contact">Contact & RDV</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>© {new Date().getFullYear()} Kiné Pour Tous — Cabinet de kinésithérapie</p>
    </footer>
    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', user => {
          if (!user) {
            window.netlifyIdentity.on('login', () => {
              document.location.href = '/admin/';
            });
          }
        });
      }
    </script>
  </body>
</html>
